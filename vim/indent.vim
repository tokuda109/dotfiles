" ------------------------------------------------------------------------------
" インデントの設定
" ------------------------------------------------------------------------------

" 自動でインデント
set autoindent

" 改行時に新しい行のインデントを前の行と同じにする
set smartindent

" タブを空白文字に展開
set expandtab

" 自動インデントでずれる幅
set shiftwidth=2

" 連続した空白に対してタブキーやバックスペースキーでカーソルが動く幅
set softtabstop=2

" 画面上でタブ文字が占める幅
set tabstop=2
